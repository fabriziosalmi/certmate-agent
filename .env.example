# =====================================================================
# certmate-agent — example environment.
# Copy to `.env` and edit. Documented per-line so a fresh operator can
# tune any one knob without re-reading the README.
# =====================================================================

# ----- LM Studio (OpenAI-compatible) -----

# Base URL of the chat + embeddings endpoint. Default is a local
# LM Studio install on the loopback; replace with a Tailscale IP for a
# remote workstation or a Cloudflare Workers AI URL in production.
LMSTUDIO_URL=http://127.0.0.1:1234/v1

# Chat model id served by LMSTUDIO_URL. Small "thinking" models like
# gemma-4-e2b need more max_tokens; switch to qwen3-8b for reliable
# native tool-calling.
LMSTUDIO_CHAT_MODEL=google/gemma-4-e2b

# Embedding model id. The same model MUST also be the one used to
# build the docs index — the store warns loudly if they don't match.
LMSTUDIO_EMBED_MODEL=text-embedding-embeddinggemma-300m

# Bearer token. LM Studio doesn't require one; "lm-studio" is the
# convention. For Cloudflare WAI or OpenAI, set the real API key.
LMSTUDIO_API_KEY=lm-studio

# How long to wait for chat completions to finish. Streaming counts
# the first-token deadline; slow CPUs may need a higher value.
LMSTUDIO_TIMEOUT_SECONDS=120


# ----- Operating mode -----

# full       — sidecar to a real CertMate instance. All tools available
#              (live state reads, write commands with confirm, admin).
# docs_only  — public mode: no CertMate connection, only docs_search +
#              help. Used for agent.certmate.org-style deployments.


# ----- CertMate instance (ignored in docs_only mode) -----

# Base URL of CertMate's REST API.

# Bearer token CertMate accepts. Use a SCOPED token (role=operator +
# allowed_domains) on v2.5.5+; the agent never needs admin scope.

# HTTP timeout for CertMate calls. 30s covers slow DNS-01 retries.


# ----- Agent service binding -----

# Interface to bind. Use 0.0.0.0 only behind a reverse proxy.
AGENT_HOST=127.0.0.1

# Port to listen on.
AGENT_PORT=8765

# SQLite path for pending actions, conversations, audit log.
AGENT_DB_PATH=./agent.db

# Where the RAG index pickle lives on disk.
AGENT_INDEX_PATH=./docs_index/index.pkl

# Comma-separated allowlist of browser origins that may call /chat and
# /tools/execute. Also drives the CSP frame-ancestors directive.
AGENT_CORS_ORIGINS=http://localhost:8000


# ----- Admin gate -----

# Secret that admin-only slash commands (e.g. /reindex) compare against.
# Leave empty to disable admin commands entirely. Sent by the client via
# the X-Agent-Admin header. Comparison is constant-time.
AGENT_ADMIN_TOKEN=


# ----- Conversation persistence (optional) -----

# When true, the agent stores conversation history in sqlite keyed by
# session_id; survives page reloads and multi-instance deployments.
# When false the client passes the full history each turn (stateless).
AGENT_PERSIST_CONVERSATIONS=false

# Days to keep persisted conversation messages before scheduled pruning.
AGENT_CONVERSATION_TTL_DAYS=30

# HMAC secret used to mint per-session tokens for /conversations/{id}
# GET/DELETE auth. Generate a long random value for production.
# Empty => process-local random (won't survive a restart, won't work
# across multiple workers).
AGENT_SESSION_SECRET=


# ----- Background cleanup scheduler -----

# Interval (seconds) between cleanup passes that prune expired pending
# actions, conversations beyond AGENT_CONVERSATION_TTL_DAYS, and audit
# rows beyond AGENT_AUDIT_TTL_DAYS. Set to 0 to disable entirely.
AGENT_CLEANUP_INTERVAL_SECONDS=3600

# Days to keep audit log rows before scheduled pruning.
AGENT_AUDIT_TTL_DAYS=90


# ----- docs_search query cache (in-memory TTL+LRU) -----

# Maximum number of cached query results.
AGENT_DOCS_CACHE_SIZE=128

# Per-entry TTL.
AGENT_DOCS_CACHE_TTL_SECONDS=300


# ----- Rate limiting (per remote IP, token bucket) -----

# Max /chat requests per minute per IP. 0 disables.
AGENT_RATELIMIT_CHAT_PER_MIN=30

# Max /tools/execute requests per minute per IP. 0 disables.
AGENT_RATELIMIT_EXECUTE_PER_MIN=30

# Max concurrent in-flight /chat SSE streams per IP. 0 disables.
AGENT_RATELIMIT_CHAT_CONCURRENCY=4


# ----- Prompt-injection guard (OWASP LLM01) -----

# Hard cap on the size of a tool_result fed back into the LLM as
# role=tool content. Larger outputs are truncated inside the marker.
AGENT_TOOL_OUTPUT_MAX_CHARS=4000


# ----- Optional RAG index bootstrap -----

# When the local index file is missing, fetch it from this URL on boot.
# Used by the docs_only deployment to pick up the GH Actions release
# artifact. Must be https://. Empty disables.
AGENT_INDEX_BOOTSTRAP_URL=

# Optional SHA-256 digest of the expected pickle bytes. When set, a
# mismatched download is moved to <name>.bootstrap.reject and not
# installed. Pickle.load on an attacker-controlled blob is RCE-by-
# design, so this is the only way to safely pin a remote artifact.
AGENT_INDEX_BOOTSTRAP_SHA256=


# ----- Optional fallback LLM (OpenRouter, OpenAI-compatible) -----

# Used only for chat completions when the primary LM Studio errors out
# or is tripped by the circuit breaker. Embeddings always stay on the
# primary. Empty api_key disables the fallback entirely.
OPENROUTER_URL=https://openrouter.ai/api/v1
OPENROUTER_API_KEY=
OPENROUTER_MODEL=meta-llama/llama-3.3-8b-instruct:free

# HTTP timeout for fallback chat completions.
OPENROUTER_TIMEOUT_SECONDS=60

# Attribution headers (OpenRouter recommends but doesn't require these).
OPENROUTER_REFERER=https://github.com/fabriziosalmi/certmate
OPENROUTER_TITLE=certmate-agent

# Circuit breaker: trip the primary after this many consecutive failures.
LLM_PRIMARY_FAILURE_THRESHOLD=3

# Keep the primary tripped for this many seconds before retrying.
LLM_PRIMARY_COOLDOWN_SECONDS=60


# ----- Behavior knobs -----

# Standard Python log level (DEBUG / INFO / WARNING / ERROR / CRITICAL).
AGENT_LOG_LEVEL=INFO

# How long a confirm token stays valid before expiring. The UI must
# POST to /tools/execute before this window closes.
AGENT_CONFIRM_TOKEN_TTL_SECONDS=300

# Maximum tool-call loop iterations per turn before bailing with an
# "exceeded iterations" error. Defensive cap against models that get
# stuck calling the same tool repeatedly.
AGENT_MAX_TOOL_ITERATIONS=6

# Max output tokens per LLM call.
AGENT_MAX_TOKENS=2048

# LLM sampling temperature. Lower = more deterministic.
AGENT_TEMPERATURE=0.2

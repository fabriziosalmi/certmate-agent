---
---
<div class="docs-search">
  <div class="search-header">
    <h3>Instant Docs Search</h3>
    <p class="muted">Sub-50ms static search powered by MiniSearch and local LLM pre-computation. Zero cloud costs.</p>
  </div>
  
  <div class="search-input-wrapper">
    <span class="search-icon">⚲</span>
    <input type="text" id="docs-search-input" placeholder="Search documentation..." autocomplete="off" />
    <span class="search-kbd"><kbd>⌘K</kbd></span>
  </div>

  <div id="search-results" class="search-results hidden">
    <!-- Results populated by JS -->
  </div>
</div>

<script>
  import MiniSearch from 'minisearch';

  const input = document.getElementById('docs-search-input') as HTMLInputElement;
  const resultsEl = document.getElementById('search-results');
  let miniSearch: MiniSearch | null = null;

  async function initSearch() {
    try {
      const response = await fetch('/brutal_qa_cache.json');
      if (!response.ok) return;
      const data = await response.json();
      
      miniSearch = new MiniSearch({
        fields: ['q_it', 'a_it', 'q_en', 'a_en', 'title'],
        storeFields: ['q_en', 'a_en', 'source', 'title'],
        idField: 'q_en',
        searchOptions: {
          boost: { title: 2, q_en: 1.5, q_it: 1.5 },
          fuzzy: 0.2
        }
      });
      miniSearch.addAll(data);
    } catch (err) {
      console.error('Failed to load search index:', err);
    }
  }

  function renderResults(results: any[]) {
    if (!resultsEl) return;
    
    if (results.length === 0) {
      resultsEl.innerHTML = '<div class="no-results">No results found.</div>';
      resultsEl.classList.remove('hidden');
      return;
    }

    resultsEl.innerHTML = results.slice(0, 5).map(res => `
      <div class="search-hit">
        <div class="hit-title">${res.title || 'Documentation'} <span class="hit-source">${res.source}</span></div>
        <div class="hit-question">${res.q_en}</div>
        <div class="hit-answer">${res.a_en}</div>
      </div>
    `).join('');
    
    resultsEl.classList.remove('hidden');
  }

  if (input) {
    // Initialize lazily on focus or first keystroke
    input.addEventListener('focus', () => {
      if (!miniSearch) initSearch();
    }, { once: true });

    input.addEventListener('input', (e) => {
      const query = (e.target as HTMLInputElement).value.trim();
      if (!query) {
        resultsEl?.classList.add('hidden');
        return;
      }
      if (miniSearch) {
        const results = miniSearch.search(query);
        renderResults(results);
      }
    });

    // Global Cmd+K / Ctrl+K
    document.addEventListener('keydown', (e) => {
      if ((e.metaKey || e.ctrlKey) && e.key === 'k') {
        e.preventDefault();
        input.focus();
      }
    });

    // Close on escape or outside click
    document.addEventListener('click', (e) => {
      if (!input.contains(e.target as Node) && !resultsEl?.contains(e.target as Node)) {
        resultsEl?.classList.add('hidden');
      }
    });
    
    input.addEventListener('keydown', (e) => {
      if (e.key === 'Escape') {
        input.blur();
        resultsEl?.classList.add('hidden');
      }
    });
  }
</script>

<style>
  .docs-search {
    margin: 48px 0;
    padding: 32px;
    background: var(--panel);
    border: 1px solid var(--border);
    border-radius: 12px;
  }
  .search-header h3 {
    margin: 0 0 8px;
    font-size: 18px;
    font-weight: 600;
  }
  .search-input-wrapper {
    position: relative;
    margin-top: 24px;
  }
  .search-icon {
    position: absolute;
    left: 14px;
    top: 50%;
    transform: translateY(-50%);
    font-size: 18px;
    color: var(--fg-muted);
    pointer-events: none;
  }
  .search-kbd {
    position: absolute;
    right: 14px;
    top: 50%;
    transform: translateY(-50%);
    pointer-events: none;
  }
  .search-kbd kbd {
    font-family: var(--font-mono);
    font-size: 11px;
    padding: 3px 6px;
    background: var(--bg);
    border: 1px solid var(--border-strong);
    border-radius: 4px;
    color: var(--fg-muted);
  }
  #docs-search-input {
    width: 100%;
    height: 48px;
    padding: 0 48px 0 40px;
    font-size: 15px;
    background: var(--bg);
    border: 1px solid var(--border-strong);
    border-radius: 8px;
    color: var(--fg);
    transition: all 0.2s;
  }
  #docs-search-input:focus {
    outline: none;
    border-color: var(--fg);
    box-shadow: 0 0 0 3px rgba(0,0,0,0.05);
  }
  :global(.dark) #docs-search-input:focus {
    box-shadow: 0 0 0 3px rgba(255,255,255,0.05);
  }
  .search-results {
    margin-top: 12px;
    background: var(--bg);
    border: 1px solid var(--border);
    border-radius: 8px;
    max-height: 400px;
    overflow-y: auto;
    box-shadow: 0 10px 25px -5px rgba(0,0,0,0.1);
  }
  .search-results.hidden {
    display: none;
  }
  .search-hit {
    padding: 16px;
    border-bottom: 1px solid var(--border);
  }
  .search-hit:last-child {
    border-bottom: none;
  }
  .hit-title {
    font-size: 12px;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    font-weight: 600;
    color: var(--fg-muted);
    margin-bottom: 8px;
    display: flex;
    justify-content: space-between;
  }
  .hit-source {
    font-family: var(--font-mono);
    font-size: 10px;
    background: var(--panel);
    padding: 2px 6px;
    border-radius: 4px;
    border: 1px solid var(--border);
  }
  .hit-question {
    font-weight: 600;
    font-size: 15px;
    margin-bottom: 6px;
    color: var(--fg);
  }
  .hit-answer {
    font-size: 14px;
    color: var(--fg-muted);
    line-height: 1.5;
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }
  .no-results {
    padding: 24px;
    text-align: center;
    color: var(--fg-muted);
    font-size: 14px;
  }
</style>

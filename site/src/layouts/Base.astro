---
import "../styles/global.css";

interface Props {
  title: string;
  description: string;
  /** Override the OG image (defaults to the CertMate logo). */
  ogImage?: string;
  /** Canonical pathname relative to site root, e.g. "/dns-01-explained/". */
  canonical?: string;
}

const { title, description, ogImage = "/og-default.png", canonical } = Astro.props;
const canonicalUrl = canonical
  ? new URL(canonical, Astro.site).toString()
  : new URL(Astro.url.pathname, Astro.site).toString();
const ogUrl = new URL(ogImage, Astro.site).toString();
---
<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="color-scheme" content="light dark" />
    <link rel="canonical" href={canonicalUrl} />

    <title>{title}</title>
    <meta name="description" content={description} />

    <meta property="og:type" content="website" />
    <meta property="og:url" content={canonicalUrl} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content={ogUrl} />

    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogUrl} />

    <link rel="icon" type="image/png" sizes="32x32" href="/favicon.png" />
    <link rel="icon" type="image/png" sizes="192x192" href="/certmate-logo.png" />
    <link rel="apple-touch-icon" href="/certmate-logo.png" />

    <slot name="head" />
  </head>
  <body>
    <header class="site-header">
      <div class="wrap header-inner">
        <a class="brand" href="/">
          <img src="/certmate-logo.png" alt="" width="26" height="26" />
          <span class="brand-name">CertMate</span>
          <span class="brand-sub">/ agent</span>
        </a>
        <nav>
          <a href="/topics/">Topics</a>
          <a href="https://www.certmate.org" rel="noopener">certmate.org</a>
          <a href="https://github.com/fabriziosalmi/certmate" rel="noopener"
             title="CertMate on GitHub" aria-label="CertMate on GitHub">
            <svg width="16" height="16" viewBox="0 0 16 16" fill="currentColor" aria-hidden="true">
              <path d="M8 0C3.58 0 0 3.58 0 8c0 3.54 2.29 6.53 5.47 7.59.4.07.55-.17.55-.38
                0-.19-.01-.82-.01-1.49-2.01.37-2.53-.49-2.69-.94-.09-.23-.48-.94-.82-1.13-.28-.15-.68-.52-.01-.53
                .63-.01 1.08.58 1.23.82.72 1.21 1.87.87 2.33.66.07-.52.28-.87.51-1.07-1.78-.2-3.64-.89-3.64-3.95
                0-.87.31-1.59.82-2.15-.08-.2-.36-1.02.08-2.12 0 0 .67-.21 2.2.82.64-.18 1.32-.27 2-.27.68 0 1.36.09 2 .27
                1.53-1.04 2.2-.82 2.2-.82.44 1.1.16 1.92.08 2.12.51.56.82 1.27.82 2.15 0 3.07-1.87 3.75-3.65 3.95.29.25.54.73.54 1.48
                0 1.07-.01 1.93-.01 2.2 0 .21.15.46.55.38A8.013 8.013 0 0 0 16 8c0-4.42-3.58-8-8-8z"/>
            </svg>
          </a>
          <a href="https://github.com/fabriziosalmi/certmate" rel="noopener" class="cta">
            Get CertMate ↗
          </a>
        </nav>
      </div>
    </header>

    <main class="wrap content">
      <slot />
    </main>

    <footer class="site-footer">
      <div class="wrap footer-inner">
        <div class="muted">
          <strong>CertMate</strong> — self-hosted SSL certificate management.
          Find the project at
          <a href="https://www.certmate.org" rel="noopener">certmate.org</a>
          or on
          <a href="https://github.com/fabriziosalmi/certmate" rel="noopener">GitHub</a>.
        </div>
        <div class="muted">
          <a href="https://www.certmate.org" rel="noopener">certmate.org</a>
          &middot;
          <a href="https://github.com/fabriziosalmi/certmate" rel="noopener">CertMate repo</a>
          &middot;
          <a href="https://github.com/fabriziosalmi/certmate-agent" rel="noopener">Agent repo</a>
          &middot;
          <a href="/sitemap.xml">Sitemap</a>
        </div>
        <div class="muted footer-note">
          Curated content on this site — no AI-generated filler.
        </div>
      </div>
    </footer>

    <style>
      .site-header {
        border-bottom: 1px solid var(--border);
        padding: 18px 0;
      }
      .header-inner {
        display: flex;
        align-items: center;
        justify-content: space-between;
        gap: 24px;
      }
      .brand {
        display: inline-flex;
        align-items: baseline;
        gap: 8px;
        color: var(--fg);
        border-bottom: none;
        letter-spacing: -0.01em;
      }
      .brand img {
        border-radius: 7px;
        align-self: center;
      }
      .brand-name {
        font-weight: 600;
        font-size: 16px;
        color: var(--fg);
      }
      .brand-sub {
        font-family: var(--font-mono);
        font-size: 12px;
        color: var(--fg-subtle);
        font-weight: 500;
      }
      nav {
        display: flex;
        gap: 4px;
        flex-wrap: wrap;
        align-items: center;
      }
      nav a {
        color: var(--fg-muted);
        border-bottom: none;
        padding: 6px 10px;
        border-radius: 6px;
        font-size: 14px;
        font-weight: 500;
      }
      nav a:hover {
        background: var(--surface);
        color: var(--fg);
      }
      nav a.cta {
        background: var(--accent);
        color: var(--accent-fg);
        padding: 7px 12px;
      }
      nav a.cta:hover {
        background: color-mix(in oklab, var(--accent) 88%, transparent);
        color: var(--accent-fg);
      }
      nav svg { vertical-align: -3px; }
      .footer-inner {
        flex-direction: column;
        align-items: flex-start;
      }
      .footer-note {
        font-size: 12px;
        opacity: 0.7;
      }
      @media (min-width: 720px) {
        .footer-inner { flex-direction: row; align-items: baseline; }
        .footer-note { margin-left: auto; }
      }

      .content {
        padding: 48px 24px 96px;
        flex: 1;
      }

      .site-footer {
        border-top: 1px solid var(--border);
        padding: 24px 0;
        font-size: 13px;
      }
      .footer-inner {
        display: flex;
        justify-content: space-between;
        gap: 24px;
        flex-wrap: wrap;
      }

      @media (max-width: 540px) {
        .site-header { padding: 14px 0; }
        .content { padding: 28px 16px 64px; }
        nav { gap: 0; }
        nav a { padding: 6px 8px; }
      }
    </style>
  </body>
</html>
